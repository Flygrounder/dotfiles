{
    "margin-top": 14,
    "margin-left": 14,
    "margin-right": 14,
    "layer": "top",
    "modules-left": [ "custom/logo", "hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["hyprland/language", "wireplumber", "backlight", "battery", "clock", "tray"],
    "clock": {
        "format": "ΎΑΩ {:%d.%m.%Y %H:%M}"
    },
    "hyprland/language": {
    	"format": "ΎΑν {}",
    	"format-en": "EN",
    	"format-ru": "RU"
    },
    "wireplumber": {
    	"format": "{icon} {volume}%",
	"format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
	"format-muted": "Όυν   {volume}%"
    },
    "custom/logo": {
    	"format": "ΎΞβ",
    },
    "tray": {
    	"spacing": 10,
    },
    "hyprland/window": {
    	"max-length": 50,
    },
    "backlight": {
        "format": "ΎΔτ {percent}%",
    },
    "battery": {
	    "format": "{icon} {capacity}% {time}",
	    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
	    "format-time": "{H}:{m}",
	    "format-charging": "≤▒ΡΜ {capacity}% {time}"
    },
}
